    <RecipeDef ParentName="DO_WheatRecipeBase">
        <defName>Make_Flour</defName>
        <label>mill wheat into flour</label>
        <description>Process wheat ears into flour at the agronomy bench.</description>
        <jobString>Milling flour.</jobString>
        <workAmount>380</workAmount>
        <workSpeedStat>GeneralLaborSpeed</workSpeedStat>
        <workSkill>Crafting</workSkill>
        <requiredGiverWorkType>Crafting</requiredGiverWorkType>
        <skillRequirements>
            <Crafting>2</Crafting>
        </skillRequirements>
        <ingredients>
            <li>
                <filter>
                    <thingDefs>
                        <li>WheatEar</li>
                    </thingDefs>
                </filter>
                <count>5</count>
            </li>
        </ingredients>
        <products>
            <Flour>4</Flour>
        </products>
        <recipeUsers>
            <li>Drac_bench_herb</li>
        </recipeUsers>
        <displayPriority>1100</displayPriority>
    </RecipeDef>

