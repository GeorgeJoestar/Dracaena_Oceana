<Defs>
  <RecipeDef>
    <defName>Make_Apparel_DO_ClothOne</defName>
    <label>make draconic commonwear</label>
    <description>Tailor draconic commonwear from textile materials while preserving its original colors.</description>
    <jobString>Tailoring draconic commonwear.</jobString>
    <workAmount>1800</workAmount>
    <workSpeedStat>GeneralLaborSpeed</workSpeedStat>
    <workSkill>Crafting</workSkill>
    <effectWorking>Tailor</effectWorking>
    <soundWorking>Recipe_Tailor</soundWorking>
    <unfinishedThingDef>UnfinishedApparel</unfinishedThingDef>
    <displayPriority>200</displayPriority>
    <recipeUsers>
      <li>Drac_bench_tailor</li>
      <li>ElectricTailoringBench</li>
      <li>HandTailoringBench</li>
      <li>CraftingSpot</li>
    </recipeUsers>
    <ingredients>
      <li>
        <filter>
          <categories>
            <li>Root</li>
          </categories>
          <stuffCategoriesToAllow>
            <li>Fabric</li>
          </stuffCategoriesToAllow>
        </filter>
        <count>55</count>
      </li>
    </ingredients>
    <fixedIngredientFilter>
      <categories>
        <li>Root</li>
      </categories>
      <stuffCategoriesToAllow>
        <li>Fabric</li>
      </stuffCategoriesToAllow>
    </fixedIngredientFilter>
    <products>
      <Apparel_DO_ClothOne>1</Apparel_DO_ClothOne>
    </products>
  </RecipeDef>

