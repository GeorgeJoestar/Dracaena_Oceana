<?xml version="1.0" encoding="utf-8"?>
<Defs>
    <HediffDef>
        <defName>DO_MilitarisBread_DryMouth</defName>
        <label>dry mouth from hard bread</label>
        <labelNoun>hard-bread dryness</labelNoun>
        <description>A lingering dry-mouth feeling after eating dense hard bread. Eating is a bit slower.</description>
        <hediffClass>HediffWithComps</hediffClass>
        <isBad>true</isBad>
        <comps>
            <li Class="HediffCompProperties_SeverityPerDay">
                <severityPerDay>-1.0</severityPerDay>
                <showHoursToRecover>true</showHoursToRecover>
            </li>
        </comps>
        <stages>
            <li>
                <statFactors>
                    <EatingSpeed>0.95</EatingSpeed>
                </statFactors>
            </li>
        </stages>
    </HediffDef>

    <HediffDef>
        <defName>DO_LeavenedBread_WorkFocus</defName>
        <label>energized by white bread</label>
        <labelNoun>white-bread focus</labelNoun>
        <description>Good fermentation and proper baking leave the body warm and focused, improving work speed for a while.</description>
        <hediffClass>HediffWithComps</hediffClass>
        <isBad>false</isBad>
        <comps>
            <li Class="HediffCompProperties_SeverityPerDay">
                <severityPerDay>-1.0</severityPerDay>
                <showHoursToRecover>true</showHoursToRecover>
            </li>
        </comps>
        <stages>
            <li>
                <statFactors>
                    <WorkSpeedGlobal>1.10</WorkSpeedGlobal>
                </statFactors>
            </li>
        </stages>
    </HediffDef>
</Defs>

