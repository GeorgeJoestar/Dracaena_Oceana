<?xml version="1.0" encoding="utf-8"?>
<Defs>
    <ThingDef ParentName="PlantBase">
        <defName>Plant_Wheat</defName>
        <label>wheat plant</label>
        <description>A staple grain crop cultivated by Dracaena settlers. It needs fertile soil and time, but supports a full milling and baking chain.</description>
        <statBases>
            <MaxHitPoints>150</MaxHitPoints>
            <Nutrition>0.4</Nutrition>
        </statBases>
        <graphicData>
            <texPath>Things/Plant/WheatPlant</texPath>
            <graphicClass>Graphic_Random</graphicClass>
        </graphicData>
        <selectable>true</selectable>
        <pathCost>14</pathCost>
        <ingestible />
        <plant>
            <fertilityMin>1.0</fertilityMin>
            <dieIfLeafless>true</dieIfLeafless>
            <harvestTag>Standard</harvestTag>
            <harvestedThingDef>WheatEar</harvestedThingDef>
            <harvestYield>15</harvestYield>
            <sowTags>
                <li>Ground</li>
            </sowTags>
            <topWindExposure>0.35</topWindExposure>
            <growDays>12</growDays>
            <immatureGraphicPath>Things/Plant/WheatPlant_Immature</immatureGraphicPath>
            <visualSizeRange>0.5~1.4</visualSizeRange>
            <wildOrder>2</wildOrder>
            <purpose>Food</purpose>
            <humanFoodPlant>true</humanFoodPlant>
        </plant>
    </ThingDef>

    <ThingDef ParentName="PlantFoodRawBase">
        <defName>WheatEar</defName>
        <label>wheat ear</label>
        <description>Harvested wheat ears. Basic grain material for porridge and flour.</description>
        <soundInteract>Grain_Drop</soundInteract>
        <soundDrop>Grain_Drop</soundDrop>
        <possessionCount>10</possessionCount>
        <graphicData>
            <texPath>Things/Item/Resource/PlantFoodRaw/WheatEar</texPath>
            <graphicClass>Graphic_StackCount</graphicClass>
            <drawSize>(1.25,1.25)</drawSize>
        </graphicData>
        <statBases>
            <MarketValue>1.1</MarketValue>
            <Nutrition>0.05</Nutrition>
            <DeteriorationRate>6</DeteriorationRate>
        </statBases>
        <ingestible>
            <foodType>Seed</foodType>
        </ingestible>
        <thingCategories>
            <li>DO_ItemCategory_WheatRaw</li>
        </thingCategories>
        <comps>
            <li Class="CompProperties_Rottable">
                <daysToRotStart>60</daysToRotStart>
                <rotDestroys>true</rotDestroys>
            </li>
        </comps>
    </ThingDef>

    <ThingDef ParentName="PlantFoodRawBase">
        <defName>Flour</defName>
        <label>wheat flour</label>
        <description>Ground wheat flour. Better digestibility than raw grain and the core input for dough and yeast.</description>
        <graphicData>
            <graphicClass>Graphic_StackCount</graphicClass>
            <texPath>Things/Item/Resource/PlantFoodRaw/WheatFlour</texPath>
        </graphicData>
        <statBases>
            <MarketValue>1.2</MarketValue>
            <Mass>0.02</Mass>
            <Nutrition>0.08</Nutrition>
        </statBases>
        <thingCategories>
            <li>DO_ItemCategory_WheatIntermediate</li>
        </thingCategories>
        <ingestible>
            <foodType>Plant</foodType>
        </ingestible>
        <comps>
            <li Class="CompProperties_Rottable">
                <daysToRotStart>80</daysToRotStart>
                <rotDestroys>true</rotDestroys>
            </li>
        </comps>
    </ThingDef>

    <ThingDef ParentName="PlantFoodRawBase">
        <defName>Yeast</defName>
        <label>yeast culture</label>
        <description>Active yeast cultivated from flour. Used to ferment dough for softer bread.</description>
        <graphicData>
            <graphicClass>Graphic_StackCount</graphicClass>
            <texPath>Things/Item/Resource/PlantFoodRaw/Yeast</texPath>
        </graphicData>
        <statBases>
            <MarketValue>1.4</MarketValue>
            <Mass>0.015</Mass>
            <Nutrition>0.12</Nutrition>
        </statBases>
        <thingCategories>
            <li>DO_ItemCategory_WheatIntermediate</li>
        </thingCategories>
        <ingestible>
            <foodType>Plant</foodType>
        </ingestible>
        <comps>
            <li Class="CompProperties_Rottable">
                <daysToRotStart>12</daysToRotStart>
                <rotDestroys>true</rotDestroys>
            </li>
        </comps>
    </ThingDef>

    <ThingDef Abstract="True" Name="DO_WheatDoughBase" ParentName="OrganicProductBase">
        <graphicData>
            <graphicClass>Graphic_StackCount</graphicClass>
        </graphicData>
        <statBases>
            <MaxHitPoints>60</MaxHitPoints>
            <Flammability>1.0</Flammability>
            <DeteriorationRate>6</DeteriorationRate>
            <Mass>0.05</Mass>
        </statBases>
        <tickerType>Rare</tickerType>
        <healthAffectsPrice>false</healthAffectsPrice>
        <ingestible>
            <foodType>Plant</foodType>
            <preferability>DesperateOnlyForHumanlikes</preferability>
            <tasteThought>AteRawFood</tasteThought>
            <ingestEffect>EatVegetarian</ingestEffect>
            <ingestSound>RawVegetable_Eat</ingestSound>
        </ingestible>
        <socialPropernessMatters>true</socialPropernessMatters>
        <thingCategories>
            <li>Foods</li>
            <li>DO_ItemCategory_WheatIntermediate</li>
        </thingCategories>
    </ThingDef>

    <ThingDef ParentName="DO_WheatDoughBase">
        <defName>UnfermentedDough</defName>
        <label>unfermented dough</label>
        <description>Simple dough mixed from flour. It can be baked into hard travel bread.</description>
        <graphicData>
            <texPath>Things/Item/Resource/PlantFoodRaw/UnfermentedDough</texPath>
        </graphicData>
        <statBases>
            <MarketValue>3.4</MarketValue>
            <Mass>0.05</Mass>
            <Nutrition>0.58</Nutrition>
        </statBases>
        <comps>
            <li Class="CompProperties_Rottable">
                <daysToRotStart>2</daysToRotStart>
                <rotDestroys>true</rotDestroys>
            </li>
        </comps>
    </ThingDef>

    <ThingDef ParentName="DO_WheatDoughBase">
        <defName>FermentedDough</defName>
        <label>fermented dough</label>
        <description>Dough proofed with yeast. Requires more preparation, but yields much better bread.</description>
        <graphicData>
            <texPath>Things/Item/Resource/PlantFoodRaw/FermentedDough</texPath>
        </graphicData>
        <statBases>
            <MarketValue>4.8</MarketValue>
            <Mass>0.055</Mass>
            <Nutrition>0.90</Nutrition>
        </statBases>
        <comps>
            <li Class="CompProperties_Rottable">
                <daysToRotStart>2</daysToRotStart>
                <rotDestroys>true</rotDestroys>
            </li>
        </comps>
    </ThingDef>

    <ThingDef ParentName="MealCooked">
        <defName>Puls</defName>
        <label>wheat porridge</label>
        <description>A thin porridge boiled from cracked wheat. Cheap and filling, but not pleasant.</description>
        <graphicData>
            <graphicClass>Graphic_StackCount</graphicClass>
            <texPath>Things/Item/Meal/Puls</texPath>
        </graphicData>
        <thingCategories>
            <li>DO_ItemCategory_WheatMeals</li>
        </thingCategories>
        <statBases>
            <MarketValue>10</MarketValue>
            <WorkToMake>260</WorkToMake>
            <Nutrition>0.45</Nutrition>
        </statBases>
        <ingestible>
            <preferability>MealAwful</preferability>
            <ingestEffect>EatVegetarian</ingestEffect>
            <ingestSound>Meal_Eat</ingestSound>
            <tasteThought>AtePuls</tasteThought>
        </ingestible>
        <comps>
            <li Class="CompProperties_Rottable">
                <daysToRotStart>2</daysToRotStart>
                <rotDestroys>true</rotDestroys>
            </li>
        </comps>
    </ThingDef>

    <ThingDef ParentName="MealCooked">
        <defName>MilitarisBread</defName>
        <label>military bread</label>
        <description>Dense, dry field bread made from unfermented dough. Long-lasting and practical.</description>
        <graphicData>
            <graphicClass>Graphic_StackCount</graphicClass>
            <texPath>Things/Item/Meal/MilitarisBread</texPath>
        </graphicData>
        <thingCategories>
            <li>DO_ItemCategory_WheatMeals</li>
        </thingCategories>
        <statBases>
            <MarketValue>16</MarketValue>
            <WorkToMake>500</WorkToMake>
            <Nutrition>0.95</Nutrition>
        </statBases>
        <ingestible>
            <preferability>MealSimple</preferability>
            <ingestEffect>EatVegetarian</ingestEffect>
            <ingestSound>Meal_Eat</ingestSound>
            <tasteThought>AteMilitarisBread</tasteThought>
            <outcomeDoers>
                <li Class="IngestionOutcomeDoer_GiveHediff">
                    <hediffDef>DO_MilitarisBread_DryMouth</hediffDef>
                    <severity>0.35</severity>
                </li>
            </outcomeDoers>
        </ingestible>
        <comps>
            <li Class="CompProperties_Rottable">
                <daysToRotStart>15</daysToRotStart>
                <rotDestroys>true</rotDestroys>
            </li>
        </comps>
    </ThingDef>

    <ThingDef ParentName="MealCooked">
        <defName>LeavenedBread</defName>
        <label>white bread</label>
        <description>Soft white bread baked from fermented dough. Time-intensive to produce, but exceptionally nourishing and satisfying.</description>
        <graphicData>
            <graphicClass>Graphic_StackCount</graphicClass>
            <texPath>Things/Item/Meal/LeavenedBread</texPath>
        </graphicData>
        <thingCategories>
            <li>DO_ItemCategory_WheatMeals</li>
        </thingCategories>
        <statBases>
            <MarketValue>24</MarketValue>
            <WorkToMake>700</WorkToMake>
            <Nutrition>1.25</Nutrition>
        </statBases>
        <ingestible>
            <preferability>MealFine</preferability>
            <ingestEffect>EatVegetarian</ingestEffect>
            <ingestSound>Meal_Eat</ingestSound>
            <tasteThought>AteLeavenedBread</tasteThought>
            <outcomeDoers>
                <li Class="IngestionOutcomeDoer_GiveHediff">
                    <hediffDef>DO_LeavenedBread_WorkFocus</hediffDef>
                    <severity>0.50</severity>
                </li>
            </outcomeDoers>
        </ingestible>
        <comps>
            <li Class="CompProperties_Rottable">
                <daysToRotStart>3</daysToRotStart>
                <rotDestroys>true</rotDestroys>
            </li>
        </comps>
    </ThingDef>
</Defs>

