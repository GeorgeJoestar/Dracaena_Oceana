<?xml version="1.0" encoding="utf-8"?>
<Defs>
    <ThingDef Name="DO_FisheriesRawBase" ParentName="PlantFoodRawBase" Abstract="True">
        <graphicData>
            <graphicClass>Graphic_StackCount</graphicClass>
        </graphicData>
        <thingCategories Inherit="False">
            <li>PlantFoodRaw</li>
            <li>DO_ItemCategory_Fisheries</li>
        </thingCategories>
        <ingestible>
            <foodType>Meat</foodType>
            <ingestEffect>EatMeat</ingestEffect>
            <ingestSound>RawMeat_Eat</ingestSound>
        </ingestible>
        <comps>
            <li Class="CompProperties_Rottable">
                <daysToRotStart>6</daysToRotStart>
                <rotDestroys>true</rotDestroys>
            </li>
        </comps>
    </ThingDef>

    <ThingDef ParentName="DO_FisheriesRawBase">
        <defName>DO_SardineRaw</defName>
        <label>sardine</label>
        <description>Fresh sardine from the pond. Small but plentiful fish for simple meals.</description>
        <graphicData>
            <texPath>Things/Item/Resource/Fisheries/Sardine</texPath>
        </graphicData>
        <statBases>
            <MarketValue>1.5</MarketValue>
            <Nutrition>0.06</Nutrition>
            <Mass>0.025</Mass>
        </statBases>
    </ThingDef>

    <ThingDef ParentName="DO_FisheriesRawBase">
        <defName>DO_ShrimpRaw</defName>
        <label>shrimp</label>
        <description>Pond shrimp. Delicate seafood that can be eaten raw in emergencies or cooked into meals.</description>
        <graphicData>
            <texPath>Things/Item/Resource/Fisheries/Shrimp</texPath>
        </graphicData>
        <statBases>
            <MarketValue>1.8</MarketValue>
            <Nutrition>0.07</Nutrition>
            <Mass>0.025</Mass>
        </statBases>
    </ThingDef>

    <ThingDef ParentName="DO_FisheriesRawBase">
        <defName>DO_SquidRaw</defName>
        <label>squid</label>
        <description>Squid harvested from a stocked improved pond. Dense and useful for higher-value food processing.</description>
        <graphicData>
            <texPath>Things/Item/Resource/Fisheries/Squid</texPath>
        </graphicData>
        <statBases>
            <MarketValue>2.3</MarketValue>
            <Nutrition>0.09</Nutrition>
            <Mass>0.03</Mass>
